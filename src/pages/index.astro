---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppCard from '../components/AppCard.astro';

const yeschefFeatures = [
  'Recipe imports',
  'Meal planning',
  'Serving size adjustment',
  'Smart grocery lists',
  'Shareable meal plans',
];

const wilsonFeatures = [
  'Asset management',
  'Maintenance scheduling',
  'Service records',
  'Email reminders',
  'Replacement tracking',
  'Dashboard',
];

---

<BaseLayout title="Jason Evans — Developer & Builder">

  <!-- ── Hero ───────────────────────────────────────────── -->
  <section class="hero anim-fade-up delay-1">
    <div class="hero-eyebrow">jasonevans.xyz</div>
    <h1>Hi, I'm<br /><em>Jason Evans.</em></h1>
    <p class="hero-desc">
      I build web applications and tools that make daily life a little easier.
      Based in Grimes, Iowa — writing code and occasionally blogging about it.
    </p>
    <a href="#apps" class="hero-cta">
      See my work <span class="hero-cta-arrow">→</span>
    </a>
  </section>

  <!-- ── Apps ───────────────────────────────────────────── -->
  <section class="apps-section anim-fade-up delay-2" id="apps">
    <div class="section-divider">
      <span>Applications</span>
    </div>

    <div class="apps-grid">
      <AppCard
        name="YesChef"
        description="A comprehensive meal planning and recipe management app that handles the entire cooking workflow — from recipe discovery to grocery shopping."
        features={yeschefFeatures}
        url="yeschef.jasonevans.xyz"
        href="https://yeschef.jasonevans.xyz"
      />

      <AppCard
        name="Wilson"
        description="Stay on top of everything in your home — appliances, HVAC, plumbing, and more. Track assets, schedule maintenance, log service history, and get ahead of costly replacements before they sneak up on you."
        features={wilsonFeatures}
        url="wilson.jasonevans.xyz"
        href="https://wilson.jasonevans.xyz"
      />

      <!-- Future app slot -->
      <a href="#" class="app-card-future">
        <div class="future-plus">+</div>
        <div class="future-label">More apps coming</div>
      </a>

      <div class="app-cell-est">
        <span class="est-label">est. 2024</span>
      </div>
    </div>
  </section>

  <!-- ── Blog ───────────────────────────────────────────── -->
  <section class="blog-section anim-fade-up delay-3">
    <div class="section-divider">
      <span>Recent writing</span>
    </div>

    <div class="blog-wip">
      <span class="wip-label">Work in progress</span>
      <p class="wip-desc">Writing is coming soon. Check back later.</p>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────────────────── */
  .hero {
    padding: 100px 48px 80px;
    max-width: 860px;
  }

  .hero-eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .hero-eyebrow::after {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: var(--accent);
    opacity: 0.4;
  }

  .hero h1 {
    font-family: var(--serif);
    font-size: clamp(42px, 6vw, 72px);
    font-weight: 400;
    line-height: 1.1;
    color: var(--text);
    margin-bottom: 24px;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--accent);
  }

  .hero-desc {
    font-size: 17px;
    color: var(--muted);
    max-width: 500px;
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    border-bottom: 1px solid rgba(126, 170, 220, 0.3);
    padding-bottom: 2px;
    transition: border-color 0.2s;
  }

  .hero-cta:hover { border-color: var(--accent); }

  .hero-cta-arrow {
    display: inline-block;
    transition: transform 0.2s;
  }

  .hero-cta:hover .hero-cta-arrow { transform: translateX(4px); }

  /* ── Apps ──────────────────────────────────────────────── */
  .apps-section {
    padding: 0 48px 80px;
  }

  .apps-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .app-card-future {
    background: var(--bg);
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 16px;
    padding: 28px 40px;
    min-height: 100px;
    text-decoration: none;
    transition: background 0.2s;
  }

  .app-card-future:hover { background: var(--surface); }

  .future-plus {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    border: 1px solid var(--border);
    border-radius: 7px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    font-size: 18px;
    transition: border-color 0.2s, color 0.2s;
  }

  .app-card-future:hover .future-plus {
    border-color: var(--accent);
    color: var(--accent);
  }

  .future-label {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.06em;
  }

  .app-cell-est {
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 28px 40px;
  }

  .est-label {
    font-family: var(--mono);
    font-size: 11px;
    color: rgba(94, 100, 117, 0.35);
    letter-spacing: 0.1em;
  }

  /* ── Blog ──────────────────────────────────────────────── */
  .blog-section {
    padding: 0 48px 80px;
  }

  .blog-wip {
    border-top: 1px solid var(--border);
    padding: 40px 0;
  }

  .wip-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .wip-desc {
    margin-top: 12px;
    font-size: 15px;
    color: var(--muted);
  }

  /* ── Responsive ────────────────────────────────────────── */
  @media (max-width: 768px) {
    .hero {
      padding: 60px 24px 48px;
    }

    .apps-section,
    .blog-section {
      padding-left: 24px;
      padding-right: 24px;
    }

    .apps-grid {
      grid-template-columns: 1fr;
    }

  }
</style>
