---
interface Props {
  emoji: string;
  headline: string;
  subline: string;
  note?: string;
}

const { emoji, headline, subline, note } = Astro.props;
---

<div class="coming-soon">
  <div class="cs-emoji">{emoji}</div>
  <h1 class="cs-headline">{headline}</h1>
  <p class="cs-subline">{subline}</p>
  {note && <p class="cs-note">{note}</p>}
  <a href="/" class="cs-back">← back to home</a>
</div>

<style>
  .coming-soon {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 60vh;
    padding: 80px 48px;
    gap: 16px;
  }

  .cs-emoji {
    font-size: 52px;
    line-height: 1;
    margin-bottom: 8px;
    animation: float 3s ease-in-out infinite;
  }

  .cs-headline {
    font-family: var(--serif);
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 400;
    color: var(--text);
    line-height: 1.15;
    max-width: 560px;
  }

  .cs-subline {
    font-size: 16px;
    color: var(--muted);
    max-width: 420px;
    line-height: 1.7;
  }

  .cs-note {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.06em;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 10px 18px;
    margin-top: 8px;
  }

  .cs-back {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.06em;
    margin-top: 16px;
    transition: color 0.2s;
  }

  .cs-back:hover { color: var(--accent); }

  @keyframes float {
    0%, 100% { transform: translateY(0);    }
    50%       { transform: translateY(-8px); }
  }
</style>
